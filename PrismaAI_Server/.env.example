# ══════════════════════════════════════════════════════════════════
# PrismaAI Server — Environment Configuration
# Copy this file to .env.development and fill in your values
# ══════════════════════════════════════════════════════════════════

NODE_ENV=development
APP_NAME=NestServer
PORT=3000
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/nest_db2?schema=public"

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=86400

# Google OAuth
EMAIL=your_email@example.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# AI API (PrismoraAI Engine endpoint)
AI_API=http://127.0.0.1:8000/docs
