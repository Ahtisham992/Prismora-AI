# ══════════════════════════════════════════════════════════════════
# PRISMORAAI ENGINE — Environment Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════

# ── API Authentication (optional – leave empty to disable) ──────
API_KEY=

# ── Gemini API (for AI-powered summarization) ──────────────────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Cloudinary (for hosting generated highlight videos) ────────
# Sign up at: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=unsigned_uploads

# ── FFmpeg Path (must have NVENC support for GPU encoding) ─────
FFMPEG_BIN_DIR=C:\path\to\ffmpeg\bin

# ── Debug Mode ─────────────────────────────────────────────────
DEBUG=false
